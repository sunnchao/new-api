{
       "buildCommand": "cd web/default && bun install && bun run build",
       "installCommand": "cd web/default && bun install",
       "outputDirectory": "./web/default/dist",
       "nodeVersion": "22.11.0",
       "headers": [
         {
           "source": "/assets/*",
           "headers": [
             {
               "key": "Cache-Control",
               "value": "public, max-age=31536000, immutable"
             }
           ]
         }
       ],
       "rewrites": [
         {
           "source": "/api/*",
           "destination": "https://api-eo.wochirou.com/api/:splat"
         },
         {
           "source": "/mj/*",
           "destination": "https://api-eo.wochirou.com/mj/:splat"
         },
         {
           "source": "/pg/*",
           "destination": "https://api-eo.wochirou.com/pg/:splat"
         },
         {
           "source": "/uploads/*",
           "destination": "https://api-eo.wochirou.com/uploads/:splat"
         }
       ]
     }